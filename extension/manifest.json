{
  "manifest_version": 3,
  "name": "Exnos",
  "version": "0.1.0",
  "description": "Live browser-state verification for AI coding agents. One call, milliseconds, truth. Free, by GOL Productions.",
  "permissions": ["scripting", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["console-tap.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_title": "Exnos - connects to the Exnos MCP server on localhost",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
